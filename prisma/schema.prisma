generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  name                 String?
  image                String?
  password             String?
  role                 Role?                @default(STUDENT)
  isManagedAccount     Boolean              @default(false)
  deletedAt            DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  bio                  String?
  professionalTitle    String?
  coverImage           String?
  socialLinks          String?
  expertiseTags        String?              @default("")
  isPortfolioPublished Boolean              @default(false)
  hourlyRate           Float?
  location             String?
  education            String?
  teachingExperience   String?
  studentViewTheme     String?              @default("DYNAMIC")
  themeColor           String?              @default("#00adef")
  logoUrl              String?
  isIncognito          Boolean              @default(false)
  notifySubmission     Boolean              @default(true)
  notifyReview         Boolean              @default(true)
  notifyWeekly         Boolean              @default(false)
  blockedUserIds       String?              @default("")
  adminRoleId          String?
  isBlocked            Boolean              @default(false)
  accounts             Account[]
  assignments          Assignment[]
  assignmentReviews    AssignmentReview[]
  certificates         Certificate[]
  classesCreated       Class[]              @relation("TeacherClasses")
  enrollments          ClassEnrollment[]
  favoriteAssignments  FavoriteAssignment[]
  favoriteLessons      FavoriteLesson[]
  following            Follower[]           @relation("Following")
  followers            Follower[]           @relation("Followers")
  lessons              Lesson[]
  lessonReviews        LessonReview[]
  notifications        Notification[]
  purchases            Purchase[]
  sessions             Session[]
  submissions          Submission[]
  inquiries            TeachingInquiry[]
  adminRole            AdminRole?           @relation("UserAdminRole", fields: [adminRoleId], references: [id])
}

model AdminRole {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]   @relation("UserAdminRole")
}

model Certificate {
  id         String    @id @default(cuid())
  userId     String
  title      String
  issuer     String
  issueDate  DateTime?
  imageUrl   String
  isVerified Boolean   @default(false)
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeachingInquiry {
  id        String   @id @default(cuid())
  teacherId String
  studentId String
  message   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model Follower {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Class {
  id            String            @id @default(cuid())
  name          String
  description   String?
  gradeLevel    String?
  classCode     String            @unique
  joinCode      String            @unique
  isJoinable    Boolean           @default(true)
  teacherId     String
  deletedAt     DateTime?
  createdAt     DateTime          @default(now())
  isBlocked     Boolean           @default(false)
  announcements Announcement[]
  assignments   AssignmentClass[]
  teacher       User              @relation("TeacherClasses", fields: [teacherId], references: [id])
  enrollments   ClassEnrollment[]
}

model ClassEnrollment {
  studentId String
  classId   String
  status    EnrollmentStatus @default(ACTIVE)
  joinedAt  DateTime         @default(now())
  nickname  String?
  notes     String?
  class     Class            @relation(fields: [classId], references: [id])
  student   User             @relation(fields: [studentId], references: [id])

  @@id([studentId, classId])
}

model Assignment {
  id                    String               @id @default(cuid())
  title                 String
  status                MaterialStatus       @default(DRAFT)
  materialType          MaterialType         @default(EXERCISE)
  teacherId             String
  defaultPoints         Float                @default(1.0)
  coefficient           Int                  @default(1)
  allowLateSubmission   Boolean              @default(false)
  timeLimit             Int?
  startTime             DateTime?
  deadline              DateTime?
  maxAttempts           Int                  @default(1)
  focusMode             Boolean              @default(false)
  showAnswers           Boolean              @default(true)
  reviewMode            ReviewMode           @default(AFTER_ALL_ATTEMPTS_EXHAUSTED)
  themeColor            String?              @default("#00adef")
  isAiGenerated         Boolean              @default(false)
  aiPrompt              String?
  deletedAt             DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  readingText           String?
  gradeLevel            String?
  subject               String?
  instructions          String?
  shortDescription      String?
  tags                  String?              @default("")
  thumbnail             String?
  videoUrl              String?
  audioUrl              String?
  viewCount             Int                  @default(0)
  publicSubmissionCount Int                  @default(0)
  isBlocked             Boolean              @default(false)
  teacher               User                 @relation(fields: [teacherId], references: [id])
  targetClasses         AssignmentClass[]
  reviews               AssignmentReview[]
  favoriteAssignments   FavoriteAssignment[]
  flashcardDeck         FlashcardDeck?
  lesson                Lesson?
  questions             Question[]
  submissions           Submission[]
}

model FlashcardDeck {
  id           String          @id @default(cuid())
  assignmentId String          @unique
  assignment   Assignment      @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  cards        FlashcardItem[]
}

model FlashcardItem {
  id         String        @id @default(cuid())
  deckId     String
  frontText  String
  backText   String
  imageUrl   String?
  orderIndex Int
  deck       FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
}

model AssignmentClass {
  assignmentId        String
  classId             String
  assignedAt          DateTime   @default(now())
  startDate           DateTime?
  dueDate             DateTime?
  timeLimit           Int?
  maxAttempts         Int?       @default(1)
  focusMode           Boolean    @default(false)
  allowLateSubmission Boolean    @default(false)
  assignment          Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  class               Class      @relation(fields: [classId], references: [id])

  @@id([assignmentId, classId])
}

model Question {
  id            String             @id @default(cuid())
  assignmentId  String
  type          QuestionType
  orderIndex    Int
  points        Float
  explanation   String?
  content       String
  mediaType     MediaType          @default(NONE)
  mediaUrl      String?
  imageUrl      String?
  audioUrl      String?
  videoUrl      String?
  isAiGenerated Boolean            @default(false)
  aiPrompt      String?
  isBanked      Boolean            @default(false)
  originalId    String?
  assignment    Assignment         @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  answers       SubmissionAnswer[]
}

model QuestionBank {
  id          String       @id @default(cuid())
  teacherId   String
  type        QuestionType
  points      Float
  explanation String?
  content     String
  mediaType   MediaType    @default(NONE)
  mediaUrl    String?
  imageUrl    String?
  audioUrl    String?
  videoUrl    String?
  subject     String?
  gradeLevel  String?
  tags        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Submission {
  id             String             @id @default(cuid())
  assignmentId   String
  studentId      String
  startedAt      DateTime           @default(now())
  submittedAt    DateTime?
  attemptNumber  Int                @default(1)
  forceSubmitted Boolean            @default(false)
  cheatCount     Int                @default(0)
  answersDraft   String?
  score          Float?
  feedback       String?
  assignment     Assignment         @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student        User               @relation(fields: [studentId], references: [id])
  answers        SubmissionAnswer[]
}

model SubmissionAnswer {
  id            String     @id @default(cuid())
  submissionId  String
  questionId    String
  studentAnswer String
  isCorrect     Boolean
  pointsAwarded Float
  question      Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  submission    Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model Lesson {
  id             String           @id @default(cuid())
  title          String
  description    String?
  videoUrl       String?
  isPremium      Boolean          @default(false)
  price          Float            @default(0)
  viewsCount     Int              @default(0)
  purchasesCount Int              @default(0)
  isEditorChoice Boolean          @default(false)
  teacherId      String
  assignmentId   String?          @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  isBlocked      Boolean          @default(false)
  favorites      FavoriteLesson[]
  assignment     Assignment?      @relation(fields: [assignmentId], references: [id])
  teacher        User             @relation(fields: [teacherId], references: [id])
  reviews        LessonReview[]
  purchases      Purchase[]
}

model FavoriteLesson {
  studentId String
  lessonId  String
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([studentId, lessonId])
}

model Purchase {
  id        String   @id @default(cuid())
  studentId String
  lessonId  String
  amount    Float
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  student   User     @relation(fields: [studentId], references: [id])
}

model SupportTicket {
  id        String   @id @default(cuid())
  email     String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  link      String?  @map("actionLink")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Announcement {
  id          String   @id @default(cuid())
  classId     String
  content     String
  authorId    String
  attachments String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
}

model FavoriteAssignment {
  studentId    String
  assignmentId String
  createdAt    DateTime   @default(now())
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([studentId, assignmentId])
}

model AssignmentReview {
  id           String     @id @default(cuid())
  studentId    String
  assignmentId String
  rating       Int
  comment      String?
  isApproved   Boolean    @default(false)
  createdAt    DateTime   @default(now())
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, assignmentId])
}

model LessonReview {
  id         String   @id @default(cuid())
  studentId  String
  lessonId   String
  rating     Int
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
}

enum Role {
  TEACHER
  STUDENT
  ADMIN
}

enum EnrollmentStatus {
  INVITED
  ACTIVE
  BLOCKED
  PENDING
}

enum MaterialType {
  EXERCISE
  READING
  FLASHCARD
}

enum MaterialStatus {
  DRAFT
  PRIVATE
  PUBLIC
}

enum ReviewMode {
  NEVER
  AFTER_EACH_ATTEMPT
  AFTER_ALL_ATTEMPTS_EXHAUSTED
  AFTER_DEADLINE
}

enum MediaType {
  NONE
  IMAGE
  VIDEO
  AUDIO
}

enum QuestionType {
  MULTIPLE_CHOICE
  CLOZE_TEST
  MATCHING
  TRUE_FALSE
  REORDER
}
